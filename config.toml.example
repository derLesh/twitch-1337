# Twitch 1337 Bot Configuration
# Copy this file to config.toml and fill in your credentials

[twitch]
# Twitch channel to monitor (without the # prefix)
channel = "REDACTED_CHANNEL"

# Bot's Twitch username
username = "your_bot_username"

# OAuth refresh token (used to get new access tokens automatically)
refresh_token = "your_refresh_token_here"

# Twitch application client ID
client_id = "your_client_id"

# Twitch application client secret
client_secret = "your_client_secret"

# Expected IRC message latency in milliseconds (used for precise 13:37 timing)
# Typical values: 50-150ms. Adjust based on your connection.
expected_latency = 89

[streamelements]
# StreamElements API token for managing bot commands
api_token = "your_streamelements_api_token"

# StreamElements channel ID (numeric ID, not channel name)
channel_id = "your_channel_id"

# Optional: OpenRouter AI configuration for the !ai command
# If not configured, the !ai command will be disabled.
# Get an API key from: https://openrouter.ai/keys
#
# [openrouter]
# api_key = "sk-or-your_openrouter_api_key"
# model = "google/gemini-2.0-flash-exp:free"  # Optional, defaults to free Gemini model

# Optional: Scheduled messages configuration
# Add [[schedules]] sections to define scheduled messages.
# The bot watches config.toml for changes and reloads schedules automatically.
#
# Example schedule (uncomment to use):
#
# [[schedules]]
# name = "hydration"
# message = "Stay hydrated! DinkDonk"
# interval = "00:30"  # Post every 30 minutes (hh:mm format)
# enabled = true
#
# [[schedules]]
# name = "stream-reminder"
# message = "Don't forget to follow!"
# interval = "01:00"  # Post every hour
# # Optional: Only post during specific dates
# start_date = "2025-01-01T00:00:00"  # ISO 8601 format
# end_date = "2025-12-31T23:59:59"
# # Optional: Only post during specific daily time window (Europe/Berlin)
# active_time_start = "18:00"  # HH:MM format
# active_time_end = "23:00"
# enabled = true
